import json

def salva_rubrica(rubrica, nome_file='rubrica.txt'):
    '''Salva i dati della rubrica in formato testuale (valori separati da virgola).'''
    with open('rubrica.txt', 'w') as file_rubrica:     # Scrivo un file con i dati dell'utente 
        for utente, dati in rubrica.items():
            file_rubrica.write(f'{utente}')             # Scrivo il nome degli utenti 
            for valore in dati.values():                # Itero sui valori dei dizionari annidati 
                file_rubrica.write(f', {valore}')       # Scrivo i dati degli utenti 
            file_rubrica.write('\n')                    # Vado a capo per ogni utente 

def leggi_file_txt(nome_file = 'rubrica.txt'):
    with open('rubrica.txt', 'r') as file_lettura:        # Leggo e stampo il contenuto del file 
        contenuto = file_lettura.read()
    return contenuto 

def salva_rubrica_json(rubrica, nome_file='rubrica.json'):
    with open('rubrica.json', 'w') as file_scrittura:          # Salvo il dizionario con la sua struttura originale in un file json
        json.dump(rubrica, file_scrittura)

def leggi_file_json(nome_file='rubrica.json'):
    with open('rubrica.json', 'r') as lettura_rubrica:        # Leggo e stampo il file 
        data = json.load(lettura_rubrica)
    return data 

