# Punto 5 
import argparse
parser = argparse.ArgumentParser()
parser.add_argument(
    '--chiavi',
    choices=['giorno', 'mese', 'anno', 'età', 'sesso', 'mail'],
    help="Scegli una chiave"
)
args = parser.parse_args()

chiave_scelta = args.chiavi
for utente, dati in rubrica.items():
    print(f'{utente}: {dati[chiave_scelta]}')