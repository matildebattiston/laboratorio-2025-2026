# Punto 1 
for utente, dati in rubrica.items(): 
    stringa = f"'{utente}'"
    for argomento, valore in dati.items():
        if type(valore) == str:
            stringa += f", '{argomento}' '{valore}'"
        else:
            stringa += f", '{argomento}' {valore}"

    print(stringa)

# Punto 2
lista_età = [[dati['età'], nome] for nome, dati in rubrica.items()]
lista_età.sort()
print(f'I nomi in ordine crescente di età:')
for age, personaggio in lista_età:
    print(personaggio)

 # Punto 3
lista_età.sort(reverse=True)
